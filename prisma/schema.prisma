generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model answers {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question_id String    @db.Uuid
  answer_text String    @db.VarChar
  is_correct  Boolean   @default(false)
  questions   questions @relation(fields: [question_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "answers_question_id_fk")

  @@index([question_id], map: "ix_answers_question_id")
}

model app_settings {
  id            String   @default("global") @db.VarChar
  setting_key   String   @unique @db.VarChar
  setting_value String   @db.VarChar
  updated_at    DateTime @default(now()) @db.Timestamptz(6)

  @@id([id, setting_key])
}

model game_sessions {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quiz_id        String           @db.Uuid
  host_name      String           @db.VarChar
  started_at     DateTime         @default(now()) @db.Timestamptz(6)
  ended_at       DateTime?        @db.Timestamptz(6)
  quizzes        quizzes          @relation(fields: [quiz_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "game_sessions_quiz_id_fk")
  player_results player_results[]

  @@index([quiz_id], map: "ix_game_sessions_quiz_id")
  @@index([started_at], map: "ix_game_sessions_started_at")
}

model player_results {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id    String        @db.Uuid
  player_name   String        @db.VarChar
  total_score   Int           @default(0)
  joined_at     DateTime      @default(now()) @db.Timestamptz(6)
  game_sessions game_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "player_results_session_id_fk")

  @@unique([session_id, player_name], map: "uq_player_results_session_player")
  @@index([session_id], map: "ix_player_results_session_id")
}

model questions {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quiz_id       String    @db.Uuid
  question_type String    @default("multiple_choice") @db.VarChar
  question_text String
  image_url     Bytes?    @db.ByteA
  time_limit    Int       @default(20)
  cooldown      Int       @default(5)
  points        Int       @default(1000)
  answers       answers[]
  quizzes       quizzes   @relation(fields: [quiz_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "questions_quiz_id_fk")

  @@index([quiz_id], map: "ix_questions_quiz_id")
  @@index([question_type], map: "ix_questions_question_type")
}

model quizzes {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject       String          @db.VarChar
  description   String?
  is_active     Boolean         @default(true)
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  updated_at    DateTime        @default(now()) @db.Timestamptz(6)
  game_sessions game_sessions[]
  questions     questions[]

  @@index([is_active], map: "ix_quizzes_is_active")
}
